            <stringProp name="RegexExtractor.regex">id=&quot;(j_idt\d+:j_idt\d+)&quot;[^&gt;]*type=&quot;password&quot;</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">j_idt6:j_idt12</stringProp>
